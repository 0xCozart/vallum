# IOTA GasKit local development example.
# Copy to .env and replace locally. Never commit real secrets.

IOTA_RPC_URL=https://api.testnet.iota.cafe
GAS_STATION_KEYPAIR=replace-with-local-testnet-sponsor-key
GAS_STATION_AUTH=replace-with-random-token
JWT_SECRET=replace-with-random-secret
DATABASE_URL=file:./data/gaskit.sqlite3

# Local GasKit policy gateway smoke configuration.
GASKIT_GATEWAY_PORT=8787
GASKIT_POLICY_PATH=examples/policies/demo-dapp.yaml
GASKIT_DEMO_APP_KEY=local-dev-demo-key
GASKIT_GATEWAY_HOST=127.0.0.1
GAS_STATION_URL=http://127.0.0.1:9527
GAS_STATION_BEARER_TOKEN=replace-with-local-gas-station-token

# Optional. Defaults to local-docker. Use managed-upstream only when an
# operator-managed Gas Station is intentionally configured at GAS_STATION_URL.
# GASKIT_GAS_STATION_RUNTIME_MODE=local-docker

# Optional local-only usage event store and authenticated operator usage API.
# Use a real local operator token in .env; never reuse app or upstream tokens.
# GASKIT_USAGE_EVENT_STORE_PATH=tmp/gaskit/usage-events.jsonl
# GASKIT_OPERATOR_USAGE_TOKEN=replace-with-local-operator-token
# GASKIT_OPERATOR_USAGE_MAX_RECENT_EVENTS=100

# Optional ignored evidence reports for non-networked status gates. Generate
# these with the matching proof commands, keep them under tmp/gaskit/, and do
# not commit them.
# GASKIT_SPONSOR_FUNDING_REPORT=tmp/gaskit/sponsor-funding-report.json
# GASKIT_SPONSOR_FAUCET_REPORT=tmp/gaskit/sponsor-faucet-request.json
# GASKIT_TESTNET_UPSTREAM_REPORT=tmp/gaskit/testnet-upstream-diagnostic.json
# GASKIT_TESTNET_DIGEST_REPORT=tmp/gaskit/testnet-digest-proof.json

# Optional live IOTA Names proof inputs. These are operator-owned values; leave
# them commented in committed examples.
# IOTA_NAMES_GRAPHQL_URL=https://replace-with-iota-names-graphql-endpoint
# IOTA_NAMES_NAME=replace-with-iota-name
# IOTA_NAMES_EXPECTED_ADDRESS=0xreplace-with-expected-address
# IOTA_NAMES_LIVE_REPORT=tmp/gaskit/iota-names-live-report.json

# Optional live IOTA Identity and VC trust-policy proof inputs. The report is
# produced by npm run smoke:iota-identity-live and the policy values are
# reviewed by npm run proof:live-status.
# IOTA_IDENTITY_PROOF_ENDPOINT=https://replace-with-identity-proof-endpoint
# IOTA_IDENTITY_PROFILE_PATH=profiles/replace-with-agent-profile.json
# IOTA_IDENTITY_LIVE_REPORT=tmp/gaskit/iota-identity-live-report.json
# IOTA_IDENTITY_TRUSTED_ISSUER_DIDS=did:iota:replace-with-trusted-issuer
# IOTA_IDENTITY_ALLOWED_VERIFICATION_METHODS=#replace-with-method
# IOTA_IDENTITY_REQUIRED_CREDENTIAL_TYPES=VerifiableCredential,AgentCapabilityCredential
# IOTA_IDENTITY_ACCEPTED_STATUS_TYPES=RevocationBitmap2022,StatusList2021Entry
# IOTA_IDENTITY_CACHE_TTL_MS=60000

# Optional production/operator evidence report pointers. These reports are
# generated only after operator-approved public/provider/release reviews.
# PACKAGE_PUBLICATION_REPORT=tmp/gaskit/package-publication-proof.json
# A2A_PUBLIC_DISCOVERY_REPORT=tmp/gaskit/a2a-public-discovery-report.json
# A2A_PUBLIC_PUSH_DELIVERY_REPORT=tmp/gaskit/a2a-public-push-delivery-report.json
# A2A_EXTERNAL_CONFORMANCE_REPORT=tmp/gaskit/a2a-external-conformance-report.json
# PAYMENT_PROVIDER_LIVE_REPORT=tmp/gaskit/payment-provider-live-proof.json
# MARKETPLACE_PRODUCTION_REPORT=tmp/gaskit/marketplace-production-proof.json
# CUSTODY_PRODUCTION_REPORT=tmp/gaskit/custody-production-proof.json
